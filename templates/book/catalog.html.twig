{% extends 'base.html.twig' %}

{% block title %}Catalogue - BiblioConnect{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header & Search -->
    <div class="mb-10 text-center sm:text-left flex flex-col sm:flex-row justify-between items-center gap-6">
        <div>
            <h1 class="font-serif text-4xl font-bold tracking-tight text-navy-900 dark:text-cream mb-2">Notre Catalogue</h1>
            <p class="text-gray-600 dark:text-gray-400">Découvrez, cherchez et réservez parmi l'ensemble de notre collection.</p>
        </div>
        
        <form method="get" class="w-full sm:w-auto flex">
            <div class="relative flex-1 sm:w-80">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </div>
                <input type="search" name="q" value="{{ query }}" placeholder="Rechercher un livre, auteur..." class="block w-full pl-10 pr-3 py-3 border border-gray-300 dark:border-navy-700 rounded-l-lg leading-5 bg-white dark:bg-navy-900 placeholder-gray-500 focus:outline-none focus:ring-1 focus:ring-amber-500 focus:border-amber-500 sm:text-sm transition-colors text-gray-900 dark:text-cream shadow-sm">
            </div>
            <button type="submit" class="px-6 py-3 bg-navy-900 dark:bg-navy-800 text-cream rounded-r-lg font-medium hover:bg-navy-800 dark:hover:bg-navy-700 transition shadow-sm border border-transparent dark:border-navy-700">
                Chercher
            </button>
        </form>
    </div>

    {% if query %}
        <div class="mb-6 p-4 rounded-lg bg-amber-50 dark:bg-amber-900/10 border border-amber-200 dark:border-amber-800/30 text-amber-800 dark:text-amber-400 font-medium flex justify-between items-center">
            <span>Résultats pour : <strong>"{{ query }}"</strong> ({{ books|length }} trouvés)</span>
            <a href="{{ path('app_book_catalog') }}" class="text-sm underline hover:no-underline">Réinitialiser</a>
        </div>
    {% endif %}

    <!-- Book Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 xl:grid-cols-5 gap-6">
        {% for book in books %}
            <a href="{{ path('app_book_detail', {id: book.id}) }}" class="group block glass-panel rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 border border-gray-100 dark:border-navy-800 flex flex-col h-full bg-white dark:bg-navy-900">
                <div class="aspect-[2/3] relative bg-gray-200 dark:bg-navy-800 overflow-hidden">
                    {% if book.coverImage %}
                        <img src="{{ asset('uploads/covers/' ~ book.coverImage) }}" alt="Couverture {{ book.title }}" class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-500">
                    {% else %}
                        <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-navy-100 to-navy-200 dark:from-navy-800 dark:to-navy-900 group-hover:scale-105 transition-transform duration-500">
                            <svg class="w-12 h-12 text-navy-300 dark:text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                        </div>
                    {% endif %}
                    
                    <div class="absolute top-2 right-2 flex flex-col gap-1">
                        {% if book.availableCopies > 0 %}
                            <span class="bg-green-500/90 text-white text-[10px] font-bold px-2 py-1 rounded shadow-sm backdrop-blur-md uppercase tracking-wider">Dispo</span>
                        {% else %}
                            <span class="bg-red-500/90 text-white text-[10px] font-bold px-2 py-1 rounded shadow-sm backdrop-blur-md uppercase tracking-wider">Emprunté</span>
                        {% endif %}
                    </div>
                </div>
                <div class="p-4 flex-1 flex flex-col">
                    <div class="flex justify-between items-start mb-1">
                        <div class="uppercase text-[10px] tracking-wider text-amber-600 dark:text-amber-500 font-semibold truncate flex-1 pr-2">
                            {% for cat in book.categories|slice(0, 1) %}{{ cat.name }}{% endfor %}
                        </div>
                        <div class="flex items-center text-amber-400">
                            <svg class="w-3 h-3 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                        </div>
                    </div>
                    <h4 class="font-serif font-bold text-navy-900 dark:text-white leading-tight mb-1 truncate">{{ book.title }}</h4>
                    <p class="text-xs text-gray-500 dark:text-gray-400 truncate w-full flex-1">
                        {% for a in book.authors %}{{ a.name }}{% if not loop.last %}, {% endif %}{% endfor %}
                    </p>
                </div>
            </a>
        {% else %}
            <div class="col-span-full py-20 text-center text-gray-500 bg-white/50 dark:bg-navy-800/50 rounded-xl border border-dashed border-gray-300 dark:border-navy-700">
                <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <h3 class="text-lg font-medium text-gray-900 dark:text-gray-200">Aucun résultat</h3>
                <p class="mt-1">Nous n'avons trouvé aucun livre correspondant à votre recherche.</p>
                {% if query %}
                    <div class="mt-6">
                        <a href="{{ path('app_book_catalog') }}" class="text-amber-600 hover:text-amber-500 font-medium">Voir tout le catalogue</a>
                    </div>
                {% endif %}
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
