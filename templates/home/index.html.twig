{% extends 'base.html.twig' %}

{% block title %}BiblioConnect - Accueil{% endblock %}

{% block body %}
    <!-- Hero Section -->
    <div class="relative overflow-hidden bg-white border-b border-gray-100 py-24 sm:py-32 lg:py-40">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="lg:grid lg:grid-cols-2 lg:gap-12 lg:items-center">
                <div>
                    <h1 class="text-4xl font-bold tracking-tighter text-primary sm:text-6xl uppercase">
                        VOTRE SAVOIR.<br>
                        NOTRE ARCHIVE.
                    </h1>
                    <p class="mt-6 text-lg leading-8 text-secondary max-w-lg">
                        Plateforme de gestion de bibliothèque épurée. Explorez notre collection, réservez en quelques clics et gérez vos lectures favorites de manière centralisée.
                    </p>
                    <div class="mt-10 flex items-center gap-x-6">
                        {% if app.user %}
                            {% if is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('app_admin_dashboard') }}" class="bg-primary text-white px-8 py-3 font-bold uppercase tracking-widest hover:bg-black transition text-sm">Administration</a>
                            {% elseif is_granted('ROLE_LIBRARIAN') %}
                                <a href="{{ path('app_librarian_dashboard') }}" class="bg-primary text-white px-8 py-3 font-bold uppercase tracking-widest hover:bg-black transition text-sm">Gestion Catalogue</a>
                            {% else %}
                                <a href="{{ path('app_book_catalog') }}" class="bg-primary text-white px-8 py-3 font-bold uppercase tracking-widest hover:bg-black transition text-sm">Explorer le Catalogue</a>
                            {% endif %}
                            <a href="{{ path('app_user_dashboard') }}" class="text-sm font-semibold leading-6 text-primary hover:underline">Mon Espace &rarr;</a>
                        {% else %}
                            <a href="{{ path('app_register') }}" class="bg-primary text-white px-8 py-3 font-bold uppercase tracking-widest hover:bg-black transition text-sm">Commencer maintenant</a>
                            <a href="{{ path('app_login') }}" class="text-sm font-semibold leading-6 text-primary hover:underline">Se connecter &rarr;</a>
                        {% endif %}
                    </div>
                </div>
                <div class="hidden lg:block">
                    <div class="grid grid-cols-2 gap-4">
                        <div class="aspect-[4/5] bg-gray-50 border border-gray-100 flex items-center justify-center p-8">
                            <svg class="w-24 h-24 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                        </div>
                        <div class="aspect-[4/5] bg-gray-50 border border-gray-100 mt-12 flex items-center justify-center p-8">
                             <svg class="w-24 h-24 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Featured Section (Restricted Content) -->
    {% if not app.user or (not is_granted('ROLE_ADMIN') and not is_granted('ROLE_LIBRARIAN')) %}
    <div class="bg-surface py-24 sm:py-32">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-end mb-16">
                <div>
                    <h2 class="text-xs font-bold uppercase tracking-widest text-secondary mb-4 underline decoration-gray-300 underline-offset-8">Derniers Ajouts</h2>
                    <p class="text-3xl font-bold tracking-tighter text-primary uppercase">Nouveautés dans la collection</p>
                </div>
                {% if app.user %}
                    <a href="{{ path('app_book_catalog') }}" class="text-sm font-bold uppercase tracking-wider text-primary border-b border-primary pb-1 hover:text-accent hover:border-accent transition">Voir tout</a>
                {% endif %}
            </div>

            {% if not app.user %}
                <div class="border border-dashed border-gray-300 p-12 text-center">
                    <p class="text-secondary mb-6">Le catalogue complet est réservé aux membres inscrits.</p>
                    <a href="{{ path('app_login') }}" class="bg-primary text-white px-8 py-3 font-bold uppercase tracking-widest hover:bg-black transition text-sm">Accéder aux ouvrages</a>
                </div>
            {% else %}
                <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-8">
                    {% for book in featuredBooks %}
                        <div class="group">
                            <div class="aspect-[2/3] bg-white border border-gray-100 overflow-hidden mb-4 group-hover:border-primary transition p-2">
                                <div class="w-full h-full bg-gray-50 flex items-center justify-center relative">
                                    <span class="text-[10px] uppercase font-bold text-gray-400 absolute top-2 right-2">ISBN: {{ book.id }}</span>
                                    <svg class="w-12 h-12 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253"></path></svg>
                                </div>
                            </div>
                            <h3 class="text-xs font-bold uppercase tracking-tight text-primary leading-tight group-hover:underline">{{ book.title }}</h3>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
    {% endif %}
{% endblock %}
