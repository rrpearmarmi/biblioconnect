{% extends 'base.html.twig' %}

{% block title %}Administration - BiblioConnect{% endblock %}

{% block body %}
<div class="bg-surface py-12 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-xs font-bold uppercase tracking-widest text-secondary mb-2 underline decoration-gray-300 underline-offset-8">Accès Total</h2>
        <h1 class="text-3xl font-bold tracking-tighter text-primary uppercase mb-8">Administration Système</h1>
    </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20" x-data="{ tab: 'users' }">
    <div class="flex gap-12 border-b border-gray-100 mb-16 overflow-x-auto whitespace-nowrap">
        <button @click="tab = 'users'" :class="tab === 'users' ? 'border-primary text-primary' : 'border-transparent text-secondary hover:text-primary'" class="pb-6 border-b-2 text-xs font-bold uppercase tracking-widest transition duration-200">Rôles & Profils</button>
        <button @click="tab = 'moderation'" :class="tab === 'moderation' ? 'border-primary text-primary' : 'border-transparent text-secondary hover:text-primary'" class="pb-6 border-b-2 text-xs font-bold uppercase tracking-widest transition duration-200">Modération Commentaires</button>
        <button @click="tab = 'system'" :class="tab === 'system' ? 'border-primary text-primary' : 'border-transparent text-secondary hover:text-primary'" class="pb-6 border-b-2 text-xs font-bold uppercase tracking-widest transition duration-200">État du Système</button>
    </div>

    <!-- Users Management Tab -->
    <div x-show="tab === 'users'" x-cloak class="space-y-6">
        <div class="bg-white border border-gray-100 overflow-hidden overflow-x-auto">
             <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-surface border-b border-gray-100 uppercase tracking-widest text-[10px] font-bold text-secondary">
                        <th class="px-6 py-4">Utilisateur</th>
                        <th class="px-6 py-4">Rôle</th>
                        <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50 text-sm">
                    <tr class="hover:bg-gray-50">
                        <td class="px-6 py-6 font-bold uppercase tracking-tighter text-primary">{{ app.user.email }}</td>
                        <td class="px-6 py-6">
                            <span class="text-[8px] bg-primary text-white px-2 py-1 font-bold uppercase tracking-widest">Admin</span>
                        </td>
                        <td class="px-6 py-6 text-right space-x-4">
                            <button class="text-primary hover:underline font-bold uppercase text-[10px]">Editer Rôle</button>
                            <button class="text-red-600 hover:underline font-bold uppercase text-[10px]">Bannir</button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Moderation Tab -->
    <div x-show="tab === 'moderation'" x-cloak class="space-y-6">
        <div class="bg-white border border-gray-100 p-8 text-center sm:p-24 border-dashed">
            <p class="text-secondary text-xs uppercase font-bold tracking-widest">Aucun commentaire en attente de modération.</p>
        </div>
    </div>

    <!-- System Status Tab -->
    <div x-show="tab === 'system'" x-cloak class="space-y-6">
        <div class="bg-white border border-gray-100 p-8 text-center sm:p-24 border-dashed">
            <p class="text-secondary text-xs uppercase font-bold tracking-widest">Le système fonctionne de manière optimale.</p>
        </div>
    </div>
</div>
{% endblock %}
