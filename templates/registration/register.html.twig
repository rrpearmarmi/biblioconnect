{% extends 'base.html.twig' %}

{% block title %}Inscription - BiblioConnect{% endblock %}

{% block body %}
<div class="flex-1 flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8 relative">
    <!-- Abstract background -->
    <div class="absolute inset-0 z-0 overflow-hidden">
        <div class="absolute top-20 right-20 w-80 h-80 bg-navy-500/10 dark:bg-navy-800/50 rounded-full blur-3xl"></div>
        <div class="absolute bottom-10 left-10 w-96 h-96 bg-amber-500/20 rounded-full blur-3xl"></div>
    </div>

    <div class="max-w-xl w-full space-y-8 glass-panel dark:bg-navy-900/80 p-8 sm:p-10 rounded-2xl shadow-xl border border-white/20 dark:border-navy-700 relative z-10">
        <div>
            <div class="flex justify-center">
                <div class="w-16 h-16 bg-gradient-to-tr from-navy-800 to-navy-900 rounded-2xl shadow-lg flex items-center justify-center text-amber-500 transform rotate-3">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path></svg>
                </div>
            </div>
            <h2 class="mt-6 text-center text-3xl font-serif font-bold text-navy-900 dark:text-white">
                Rejoignez-nous
            </h2>
            <p class="mt-2 text-center text-sm text-gray-600 dark:text-gray-400">
                Vous avez déjà un compte ?
                <a href="{{ path('app_login') }}" class="font-medium text-amber-600 hover:text-amber-500 transition">
                    Connectez-vous
                </a>
            </p>
        </div>

        {{ form_start(registrationForm, {'attr': {'class': 'mt-8 space-y-6', 'novalidate': 'novalidate'}}) }}
            
            {% if not registrationForm.vars.valid %}
                <div class="bg-red-50 dark:bg-red-900/30 text-red-700 dark:text-red-400 p-3 rounded-lg text-sm border border-red-200 dark:border-red-800 mb-4">
                    {{ form_errors(registrationForm) }}
                </div>
            {% endif %}

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    {{ form_label(registrationForm.firstName, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 dark:text-gray-300'}}) }}
                    <div class="mt-1 relative rounded-md shadow-sm">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                        </div>
                        {{ form_widget(registrationForm.firstName, {'attr': {'class': 'pl-10 appearance-none block w-full px-3 py-2 border border-gray-300 dark:border-navy-700 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-amber-500 focus:border-amber-500 sm:text-sm dark:bg-navy-800 dark:text-white', 'placeholder': 'Jean'}}) }}
                    </div>
                    <div class="text-sm text-red-600 mt-1">{{ form_errors(registrationForm.firstName) }}</div>
                </div>
                <div>
                    {{ form_label(registrationForm.lastName, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 dark:text-gray-300'}}) }}
                    <div class="mt-1 relative rounded-md shadow-sm">
                        {{ form_widget(registrationForm.lastName, {'attr': {'class': 'appearance-none block w-full px-3 py-2 border border-gray-300 dark:border-navy-700 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-amber-500 focus:border-amber-500 sm:text-sm dark:bg-navy-800 dark:text-white', 'placeholder': 'Dupont'}}) }}
                    </div>
                    <div class="text-sm text-red-600 mt-1">{{ form_errors(registrationForm.lastName) }}</div>
                </div>
            </div>

            <div>
                {{ form_label(registrationForm.email, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 dark:text-gray-300'}}) }}
                <div class="mt-1 relative rounded-md shadow-sm">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    </div>
                    {{ form_widget(registrationForm.email, {'attr': {'class': 'pl-10 appearance-none block w-full px-3 py-2 border border-gray-300 dark:border-navy-700 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-amber-500 focus:border-amber-500 sm:text-sm dark:bg-navy-800 dark:text-white', 'placeholder': 'jean.dupont@exemple.com'}}) }}
                </div>
                <div class="text-sm text-red-600 mt-1">{{ form_errors(registrationForm.email) }}</div>
            </div>

            <div>
                {{ form_label(registrationForm.phone, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 dark:text-gray-300'}}) }}
                <div class="mt-1 relative rounded-md shadow-sm">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                    </div>
                    {{ form_widget(registrationForm.phone, {'attr': {'class': 'pl-10 appearance-none block w-full px-3 py-2 border border-gray-300 dark:border-navy-700 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-amber-500 focus:border-amber-500 sm:text-sm dark:bg-navy-800 dark:text-white', 'placeholder': '06 12 34 56 78'}}) }}
                </div>
                <div class="text-sm text-red-600 mt-1">{{ form_errors(registrationForm.phone) }}</div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div x-data="{ show: false }">
                    {{ form_label(registrationForm.plainPassword.first, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 dark:text-gray-300'}}) }}
                    <div class="mt-1 relative rounded-md shadow-sm">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                        </div>
                        {{ form_widget(registrationForm.plainPassword.first, {'attr': {'x-bind:type': "show ? 'text' : 'password'", 'class': 'pl-10 appearance-none block w-full px-3 py-2 border border-gray-300 dark:border-navy-700 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-amber-500 focus:border-amber-500 sm:text-sm dark:bg-navy-800 dark:text-white', 'placeholder': '••••••••'}}) }}
                        <button type="button" @click="show = !show" class="absolute inset-y-0 right-0 pr-3 flex items-center">
                            <svg x-show="!show" class="h-4 w-4 text-gray-400 hover:text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                            <svg x-show="show" x-cloak class="h-4 w-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"></path></svg>
                        </button>
                    </div>
                    <div class="text-sm text-red-600 mt-1">{{ form_errors(registrationForm.plainPassword.first) }}</div>
                </div>
                <div x-data="{ show: false }">
                    {{ form_label(registrationForm.plainPassword.second, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 dark:text-gray-300'}}) }}
                    <div class="mt-1 relative rounded-md shadow-sm">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                        </div>
                        {{ form_widget(registrationForm.plainPassword.second, {'attr': {'x-bind:type': "show ? 'text' : 'password'", 'class': 'pl-10 appearance-none block w-full px-3 py-2 border border-gray-300 dark:border-navy-700 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-amber-500 focus:border-amber-500 sm:text-sm dark:bg-navy-800 dark:text-white', 'placeholder': '••••••••'}}) }}
                    </div>
                    <div class="text-sm text-red-600 mt-1">{{ form_errors(registrationForm.plainPassword.second) }}</div>
                </div>
            </div>

            <div>
                <button type="submit" class="w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-md shadow-amber-500/20 text-sm font-medium text-navy-950 bg-amber-500 hover:bg-amber-400 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-amber-500 transition-all">
                    Créer mon compte
                </button>
            </div>
            
        {{ form_end(registrationForm) }}
    </div>
</div>
{% endblock %}
