{% extends 'base.html.twig' %}

{% block title %}Dashboard Bibliothécaire - BiblioConnect{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header -->
    <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between border-b border-gray-200 dark:border-navy-800 pb-6 gap-4">
        <div>
            <h1 class="font-serif text-4xl font-bold tracking-tight text-navy-900 dark:text-cream mb-2">Espace Bibliothécaire</h1>
            <p class="text-gray-600 dark:text-gray-400">Gérez le catalogue et les réservations des utilisateurs.</p>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-12">
        <a href="#" class="glass-panel rounded-xl p-6 border border-gray-100 dark:border-navy-800 hover:border-amber-500 transition group">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-amber-100 dark:bg-amber-900/20 text-amber-600 flex items-center justify-center group-hover:scale-110 transition-transform">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                </div>
                <div>
                    <h3 class="text-2xl font-bold text-navy-900 dark:text-white group-hover:text-amber-500">Gérer le Catalogue</h3>
                    <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Ajouter/Modifier des livres</p>
                </div>
            </div>
        </a>
        <a href="#" class="glass-panel rounded-xl p-6 border border-gray-100 dark:border-navy-800 hover:border-amber-500 transition group">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-blue-100 dark:bg-blue-900/20 text-blue-600 flex items-center justify-center group-hover:scale-110 transition-transform">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
                </div>
                <div>
                    <h3 class="text-2xl font-bold text-navy-900 dark:text-white group-hover:text-blue-500">Gérer les Réservations</h3>
                    <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Suivre les emprunts en cours</p>
                </div>
            </div>
        </a>
    </div>
</div>
{% endblock %}
