<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}BiblioConnect{% endblock %}</title>

    <meta name="description" content="Gestion de bibliothèque simple et efficace.">

    <!-- Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.13.3/dist/cdn.min.js"></script>

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        primary: '#0F172A', // Navy/Slate
                        secondary: '#64748B', // Slate gray
                        accent: '#2563EB', // Simple Blue
                        surface: '#F8FAFC',
                    }
                }
            }
        }
    </script>
    
    <style>
        [x-cloak] { display: none !important; }
        .btn {
            @apply inline-flex items-center justify-center px-4 py-2 text-sm font-medium transition-all duration-200 rounded-none border border-transparent;
        }
        .btn-primary {
            @apply bg-primary text-white hover:bg-black;
        }
        .btn-outline {
            @apply border-primary text-primary hover:bg-primary hover:text-white;
        }
        .input-field {
            @apply mt-1 block w-full rounded-none border-gray-300 shadow-none focus:border-primary focus:ring-0 sm:text-sm;
        }
    </style>

    {% block stylesheets %}{% endblock %}
    {% block javascripts %}{% endblock %}
</head>
<body class="bg-white text-primary font-sans antialiased min-h-screen flex flex-col">

    <!-- Header -->
    <header class="border-b border-gray-100 bg-white sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-20">
                <!-- Branding -->
                <div class="flex items-center">
                    {% set brand_url = path('app_home') %}
                    {% if app.user %}
                        {% if is_granted('ROLE_ADMIN') %}
                            {% set brand_url = path('app_admin_dashboard') %}
                        {% elseif is_granted('ROLE_LIBRARIAN') %}
                            {% set brand_url = path('app_librarian_dashboard') %}
                        {% else %}
                            {% set brand_url = path('app_user_dashboard') %}
                        {% endif %}
                    {% endif %}
                    <a href="{{ brand_url }}" class="flex items-center gap-2">
                        <div class="w-8 h-8 bg-primary flex items-center justify-center text-white font-bold text-lg">B</div>
                        <span class="font-bold text-xl tracking-tighter uppercase">BiblioConnect</span>
                    </a>
                </div>

                <!-- Navigation -->
                <nav class="hidden md:flex items-center space-x-10 text-sm font-semibold tracking-wide uppercase">
                    {% if app.user %}
                        {% if not is_granted('ROLE_ADMIN') and not is_granted('ROLE_LIBRARIAN') %}
                            <a href="{{ path('app_book_catalog') }}" class="hover:text-secondary border-b-2 border-transparent hover:border-primary py-1">Catalogue</a>
                        {% endif %}
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('app_admin_dashboard') }}" class="hover:text-secondary">Administration</a>
                        {% elseif is_granted('ROLE_LIBRARIAN') %}
                            <a href="{{ path('app_librarian_dashboard') }}" class="hover:text-secondary">Bibliothécaire</a>
                        {% else %}
                            <a href="{{ path('app_user_dashboard') }}" class="hover:text-secondary">Mon Profil</a>
                        {% endif %}

                        <a href="{{ path('app_logout') }}" class="text-secondary hover:text-red-600 transition">Déconnexion</a>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="hover:text-secondary">Connexion</a>
                        <a href="{{ path('app_register') }}" class="bg-primary text-white px-6 py-2 hover:bg-black transition">S'inscrire</a>
                    {% endif %}
                </nav>

                <!-- Mobile menu button -->
                <div class="md:hidden flex items-center" x-data="{ open: false }">
                    <button @click="open = !open" class="text-primary p-2">
                        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                    </button>
                    
                    <div x-show="open" @click.away="open = false" x-cloak class="absolute top-20 right-0 w-full bg-white border-b border-gray-100 z-50 p-4 space-y-4 text-xs font-bold uppercase tracking-widest flex flex-col items-center">
                        {% if app.user %}
                            {% if not is_granted('ROLE_ADMIN') and not is_granted('ROLE_LIBRARIAN') %}
                                <a href="{{ path('app_book_catalog') }}" class="hover:text-secondary py-2 w-full text-center">Catalogue</a>
                            {% endif %}
                            
                            {% if is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('app_admin_dashboard') }}" class="hover:text-secondary py-2 w-full text-center">Administration</a>
                            {% elseif is_granted('ROLE_LIBRARIAN') %}
                                <a href="{{ path('app_librarian_dashboard') }}" class="hover:text-secondary py-2 w-full text-center">Bibliothécaire</a>
                            {% else %}
                                <a href="{{ path('app_user_dashboard') }}" class="hover:text-secondary py-2 w-full text-center">Mon Profil</a>
                            {% endif %}
                            
                            <a href="{{ path('app_logout') }}" class="text-secondary hover:text-red-600 transition py-2 w-full text-center">Déconnexion</a>
                        {% else %}
                            <a href="{{ path('app_login') }}" class="hover:text-secondary py-2 w-full text-center">Connexion</a>
                            <a href="{{ path('app_register') }}" class="bg-primary text-white px-6 py-4 hover:bg-black transition w-full text-center">S'inscrire</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Flash Messages -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="p-4 mb-4 text-sm font-medium border-l-4 {% if label == 'success' %}bg-green-50 text-green-700 border-green-500{% elseif label == 'error' %}bg-red-50 text-red-700 border-red-500{% else %}bg-blue-50 text-blue-700 border-blue-500{% endif %}" role="alert">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    <!-- Main -->
    <main class="flex-grow">
        {% block body %}{% endblock %}
    </main>

    <!-- Footer -->
    {% if not is_granted('ROLE_ADMIN') and not is_granted('ROLE_LIBRARIAN') %}
    <footer class="border-t border-gray-100 bg-surface sm:py-16 py-8 mt-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-4 gap-12">
            <div class="col-span-1 md:col-span-2">
                <span class="font-bold text-lg tracking-tighter uppercase">BiblioConnect</span>
                <p class="mt-4 text-secondary text-sm max-w-sm">Système de gestion de bibliothèque épuré et fonctionnel. Conçu pour la clarté et l'efficacité.</p>
            </div>
            <div>
                <h4 class="font-bold text-xs uppercase tracking-widest text-primary mb-6">Liens</h4>
                <ul class="space-y-4 text-sm text-secondary">
                    <li><a href="{{ path('app_home') }}" class="hover:text-primary">Accueil</a></li>
                    {% if app.user %}
                        <li><a href="{{ path('app_book_catalog') }}" class="hover:text-primary">Catalogue</a></li>
                    {% endif %}
                </ul>
            </div>
            <div>
                <h4 class="font-bold text-xs uppercase tracking-widest text-primary mb-6">Légal</h4>
                <ul class="space-y-4 text-sm text-secondary">
                    <li><a href="#" class="hover:text-primary">Confidentialité</a></li>
                    <li><a href="#" class="hover:text-primary">Conditions</a></li>
                </ul>
            </div>
        </div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-16 pt-8 border-t border-gray-200/50 text-[10px] uppercase tracking-[0.2em] text-secondary text-center">
            &copy; {{ 'now'|date('Y') }} Biblioconnect. Simple process. Clear results.
        </div>
    </footer>
    {% endif %}

</body>
</html>
