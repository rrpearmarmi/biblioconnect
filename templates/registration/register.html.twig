{% extends 'base.html.twig' %}

{% block title %}Inscription - BiblioConnect{% endblock %}

{% block body %}
<div class="flex-grow flex items-center justify-center p-8 bg-surface">
    <div class="w-full max-w-lg">
        <div class="bg-white border border-gray-100 p-8 sm:p-16">
            <h2 class="text-xs font-bold uppercase tracking-widest text-secondary mb-2 underline decoration-gray-300 underline-offset-8">Remplir le Formulaire</h2>
            <h1 class="text-3xl font-bold tracking-tighter text-primary uppercase mb-12">Création de Compte</h1>

            {{ form_start(registrationForm) }}
                <div class="space-y-8">
                    <div class="grid grid-cols-2 gap-8">
                        <div>
                            <label for="{{ registrationForm.firstName.vars.id }}" class="block text-[10px] uppercase font-bold tracking-widest text-secondary mb-2">Prénom</label>
                            {{ form_widget(registrationForm.firstName, {'attr': {'class': 'w-full p-4 bg-surface border border-gray-100 focus:border-primary focus:outline-none text-sm transition-colors'}}) }}
                            {{ form_errors(registrationForm.firstName, {'attr': {'class': 'text-red-600 text-[10px] mt-1'}}) }}
                        </div>
                        <div>
                            <label for="{{ registrationForm.lastName.vars.id }}" class="block text-[10px] uppercase font-bold tracking-widest text-secondary mb-2">Nom</label>
                            {{ form_widget(registrationForm.lastName, {'attr': {'class': 'w-full p-4 bg-surface border border-gray-100 focus:border-primary focus:outline-none text-sm transition-colors'}}) }}
                            {{ form_errors(registrationForm.lastName, {'attr': {'class': 'text-red-600 text-[10px] mt-1'}}) }}
                        </div>
                    </div>

                    <div>
                        <label for="{{ registrationForm.email.vars.id }}" class="block text-[10px] uppercase font-bold tracking-widest text-secondary mb-2">Adresse Email</label>
                        {{ form_widget(registrationForm.email, {'attr': {'class': 'w-full p-4 bg-surface border border-gray-100 focus:border-primary focus:outline-none text-sm transition-colors'}}) }}
                        {{ form_errors(registrationForm.email, {'attr': {'class': 'text-red-600 text-[10px] mt-1'}}) }}
                    </div>

                    <div>
                        <label for="{{ registrationForm.plainPassword.first.vars.id }}" class="block text-[10px] uppercase font-bold tracking-widest text-secondary mb-2">Mot de Passe</label>
                        {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'w-full p-4 bg-surface border border-gray-100 focus:border-primary focus:outline-none text-sm transition-colors'}}) }}
                        {{ form_errors(registrationForm.plainPassword.first, {'attr': {'class': 'text-red-600 text-[10px] mt-1'}}) }}
                    </div>

                    <div>
                        <label for="{{ registrationForm.plainPassword.second.vars.id }}" class="block text-[10px] uppercase font-bold tracking-widest text-secondary mb-2">Confirmer le Mot de Passe</label>
                        {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'w-full p-4 bg-surface border border-gray-100 focus:border-primary focus:outline-none text-sm transition-colors'}}) }}
                        {{ form_errors(registrationForm.plainPassword.second, {'attr': {'class': 'text-red-600 text-[10px] mt-1'}}) }}
                    </div>

                    <div class="pt-8 flex items-center justify-between gap-12">
                         <div class="text-[10px] font-bold uppercase tracking-tight text-secondary max-w-[200px] leading-tight">
                            En créant un compte, vous acceptez nos <a href="#" class="underline text-primary hover:text-black transition">CGU</a>.
                        </div>
                        <button type="submit" class="bg-primary text-white px-10 py-5 font-bold uppercase tracking-widest hover:bg-black transition text-sm">S'enregistrer</button>
                    </div>
                </div>
            {{ form_end(registrationForm) }}

            <div class="mt-16 pt-8 border-t border-gray-50 text-xs font-bold uppercase tracking-tighter">
                Déjà membre ? <a href="{{ path('app_login') }}" class="text-secondary hover:text-primary underline decoration-gray-200">Connectez-vous ici</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
