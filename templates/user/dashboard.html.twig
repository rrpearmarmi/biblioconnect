{% extends 'base.html.twig' %}

{% block title %}Mon Espace - BiblioConnect{% endblock %}

{% block body %}
<div class="bg-surface py-12 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-xs font-bold uppercase tracking-widest text-secondary mb-2 underline decoration-gray-300 underline-offset-8">Espace Client</h2>
        <h1 class="text-3xl font-bold tracking-tighter text-primary uppercase mb-8">Tableau de Bord</h1>
        
        <div class="flex items-center gap-4 py-8">
            <div class="w-16 h-16 bg-primary text-white flex items-center justify-center font-bold text-xl uppercase tracking-tighter">
                {{ app.user.firstName[:1] }}{{ app.user.lastName[:1] }}
            </div>
            <div>
                <p class="text-lg font-bold tracking-tighter uppercase text-primary leading-none">{{ app.user.firstName }} {{ app.user.lastName }}</p>
                <p class="text-xs uppercase font-bold tracking-widest text-gray-400 mt-2 italic">{{ app.user.email }}</p>
            </div>
        </div>
    </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20" x-data="{ tab: 'reservations' }">
    <div class="flex gap-12 border-b border-gray-100 mb-16 overflow-x-auto whitespace-nowrap">
        <button @click="tab = 'reservations'" :class="tab === 'reservations' ? 'border-primary text-primary' : 'border-transparent text-secondary hover:text-primary'" class="pb-6 border-b-2 text-xs font-bold uppercase tracking-widest transition duration-200">Mes Réservations ({{ reservations|length }})</button>
        <button @click="tab = 'favorites'" :class="tab === 'favorites' ? 'border-primary text-primary' : 'border-transparent text-secondary hover:text-primary'" class="pb-6 border-b-2 text-xs font-bold uppercase tracking-widest transition duration-200">Mes Favoris ({{ favorites|length }})</button>
        <button @click="tab = 'reviews'" :class="tab === 'reviews' ? 'border-primary text-primary' : 'border-transparent text-secondary hover:text-primary'" class="pb-6 border-b-2 text-xs font-bold uppercase tracking-widest transition duration-200">Mes Avis ({{ reviews|length }})</button>
    </div>

    <!-- Reservations Tab -->
    <div x-show="tab === 'reservations'" x-cloak class="space-y-6">
        {% if reservations is empty %}
            <div class="bg-white border border-gray-100 p-8 text-center sm:p-24 border-dashed">
                <p class="text-secondary text-xs uppercase font-bold tracking-widest mb-6">Vous n'avez aucune réservation active.</p>
                <a href="{{ path('app_book_catalog') }}" class="bg-primary text-white px-8 py-3 font-bold uppercase tracking-widest hover:bg-black transition text-xs">Parcourir le catalogue</a>
            </div>
        {% else %}
            <div class="bg-white border border-gray-100 overflow-hidden">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-surface border-b border-gray-100 uppercase tracking-widest text-[10px] font-bold text-secondary">
                            <th class="px-6 py-4">Ouvrage</th>
                            <th class="px-6 py-4">Dates</th>
                            <th class="px-6 py-4">Statut</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50 text-xs font-bold">
                        {% for reservation in reservations %}
                            <tr class="hover:bg-gray-50 uppercase tracking-tight">
                                <td class="px-6 py-6 text-primary">{{ reservation.book.title }}</td>
                                <td class="px-6 py-6 text-secondary">{{ reservation.startDate|date('d/m/Y') }} &rarr; {{ reservation.endDate|date('d/m/Y') }}</td>
                                <td class="px-6 py-6 font-bold uppercase tracking-widest">
                                    <span class="{% if reservation.status == 'pending' %}text-accent{% elseif reservation.status == 'returned' %}text-green-600{% else %}text-red-500{% endif %}">
                                        {{ reservation.status }}
                                    </span>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>

    <!-- Favorites Tab -->
    <div x-show="tab === 'favorites'" x-cloak class="space-y-6">
        {% if favorites is empty %}
            <div class="bg-white border border-gray-100 p-8 text-center sm:p-24 border-dashed">
                <p class="text-secondary text-xs uppercase font-bold tracking-widest">Votre bibliothèque est vide.</p>
            </div>
        {% else %}
            <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-8">
                {% for favorite in favorites %}
                    <div class="group border border-gray-100 p-4 hover:border-primary transition duration-300">
                        <div class="aspect-[2/3] bg-surface flex items-center justify-center mb-4 group-hover:scale-95 transition">
                             <svg class="w-8 h-8 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253"></path></svg>
                        </div>
                        <h3 class="text-[10px] font-bold uppercase tracking-tight text-primary leading-tight truncate">
                            <a href="{{ path('app_book_detail', {'id': favorite.book.id}) }}">{{ favorite.book.title }}</a>
                        </h3>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    <!-- Reviews Tab -->
    <div x-show="tab === 'reviews'" x-cloak class="space-y-6">
        {% if reviews is empty %}
            <div class="bg-white border border-gray-100 p-8 text-center sm:p-24 border-dashed">
                <p class="text-secondary text-xs uppercase font-bold tracking-widest">Aucune critique publiée.</p>
            </div>
        {% else %}
            <div class="space-y-4">
                {% for review in reviews %}
                    <div class="bg-white border border-gray-100 p-6">
                        <div class="flex justify-between items-start mb-4">
                            <span class="text-[10px] font-bold uppercase tracking-widest text-primary">{{ review.book.title }}</span>
                            <div class="flex gap-1">
                                {% for i in 1..5 %}
                                    <svg class="w-3 h-3 {% if i <= review.rating %}text-primary{% else %}text-gray-100{% endif %}" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                                {% endfor %}
                            </div>
                        </div>
                        <p class="text-xs text-secondary leading-relaxed italic">{{ review.comment }}</p>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
