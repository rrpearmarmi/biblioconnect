{% extends 'base.html.twig' %}

{% block title %}{{ book.title }} - BiblioConnect{% endblock %}

{% block body %}
<div class="bg-surface py-12 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <nav class="flex mb-8 text-[10px] font-bold uppercase tracking-widest text-secondary overflow-x-auto whitespace-nowrap pb-2">
            <a href="{{ path('app_home') }}" class="hover:text-primary transition">Accueil</a>
            <span class="mx-2">/</span>
            <a href="{{ path('app_book_catalog') }}" class="hover:text-primary transition">Catalogue</a>
            <span class="mx-2 text-gray-200">/</span>
            <span class="text-primary">{{ book.title }}</span>
        </nav>
        
        <div class="lg:grid lg:grid-cols-12 lg:gap-24 items-start">
            <!-- Book Cover Placeholder -->
            <div class="lg:col-span-4 mb-12 lg:mb-0">
                <div class="aspect-[3/4] bg-white border border-gray-200 p-4 shadow-sm group-hover:border-primary transition duration-300">
                    <div class="w-full h-full bg-surface flex flex-col items-center justify-center p-8 text-center border border-gray-50">
                        <svg class="w-24 h-24 text-gray-200 mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                        <p class="text-[10px] uppercase font-bold tracking-widest text-gray-400">ID COLLECTION: #{{ book.id }}</p>
                    </div>
                </div>
            </div>

            <!-- Content -->
            <div class="lg:col-span-8">
                <div class="flex justify-between items-start mb-4">
                    <h2 class="text-xs font-bold uppercase tracking-widest text-secondary underline decoration-gray-300 underline-offset-8">Détails de l'Ouvrage</h2>
                    {% if book.availableCopies > 0 %}
                        <span class="text-xs bg-green-50 text-green-700 px-4 py-1 font-bold uppercase tracking-widest border border-green-100">En Stock ({{ book.availableCopies }} ex.)</span>
                    {% else %}
                        <span class="text-xs bg-red-50 text-red-700 px-4 py-1 font-bold uppercase tracking-widest border border-red-100">Indisponible</span>
                    {% endif %}
                </div>

                <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tighter text-primary uppercase leading-none mb-8">{{ book.title }}</h1>
                
                <div class="flex flex-wrap gap-x-12 gap-y-6 mb-12 border-y border-gray-100 py-8 text-sm uppercase font-bold tracking-tighter">
                    <div>
                        <span class="block text-[8px] text-gray-400 mb-1">Auteurs</span>
                        <span class="text-primary underline decoration-gray-100">Plusieurs auteurs</span>
                    </div>
                    <div>
                        <span class="block text-[8px] text-gray-400 mb-1">Publié en</span>
                        <span class="text-primary">{{ book.publishedYear|default('N/A') }}</span>
                    </div>
                     <div>
                        <span class="block text-[8px] text-gray-400 mb-1">Langues</span>
                        <span class="text-primary">Français</span>
                    </div>
                </div>

                <div class="prose prose-sm prose-slate max-w-none text-secondary leading-relaxed mb-12">
                    <p>{{ book.description|default('Aucune description disponible pour cet ouvrage.') }}</p>
                </div>

                <div class="flex flex-wrap gap-4 mt-12 pt-12 border-t border-gray-100">
                    {% if book.availableCopies > 0 %}
                        <form method="post">
                            <button type="submit" class="bg-primary text-white px-12 py-5 font-bold uppercase tracking-widest hover:bg-black transition text-sm">Réserver l'Ouvrage</button>
                        </form>
                    {% endif %}
                    <form method="post">
                        <button type="submit" class="border border-primary text-primary px-12 py-5 font-bold uppercase tracking-widest hover:bg-primary hover:text-white transition text-sm">Ajouter aux Favoris</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Reviews Section -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="flex justify-between items-end mb-16">
        <div>
            <h2 class="text-xs font-bold uppercase tracking-widest text-secondary mb-4 underline decoration-gray-300 underline-offset-8">Commentaires</h2>
            <p class="text-3xl font-bold tracking-tighter text-primary uppercase">Critiques des lecteurs</p>
        </div>
        <button class="text-sm font-bold uppercase tracking-wider text-primary border-b border-primary pb-1 hover:opacity-70 transition">Donner mon avis</button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div class="border border-dashed border-gray-200 p-12 text-center flex flex-col items-center justify-center">
            <div class="flex gap-1 mb-4">
                {% for i in 1..5 %}
                <svg class="w-6 h-6 text-gray-200" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                {% endfor %}
            </div>
            <p class="text-xs font-bold uppercase tracking-widest text-gray-400">Aucune critique enregistrée pour le moment.</p>
        </div>
    </div>
</div>
{% endblock %}
