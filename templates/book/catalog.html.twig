{% extends 'base.html.twig' %}

{% block title %}Catalogue - BiblioConnect{% endblock %}

{% block body %}
<div class="bg-surface py-12 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-xs font-bold uppercase tracking-widest text-secondary mb-2 underline decoration-gray-300 underline-offset-8">Collection Complète</h2>
        <h1 class="text-3xl font-bold tracking-tighter text-primary uppercase mb-8">Notre Catalogue</h1>

        <!-- Search Bar -->
        <div class="mt-8 max-w-2xl bg-white border border-gray-100 p-2 flex gap-2">
            <form action="{{ path('app_book_catalog') }}" method="get" class="flex-grow flex gap-2">
                <div class="flex-grow relative">
                    <input type="text" name="q" value="{{ query }}" placeholder="Titre, Auteur, Catégorie..." class="w-full p-4 bg-surface border-none focus:outline-none text-sm transition-colors">
                </div>
                <button type="submit" class="bg-primary text-white px-8 py-4 font-bold uppercase tracking-widest hover:bg-black transition text-xs">Chercher</button>
            </form>
        </div>

        {% if query %}
            <p class="mt-6 text-sm font-bold uppercase tracking-tight text-secondary">
                Résultats pour : <span class="text-primary">"{{ query }}"</span>
            </p>
        {% endif %}
    </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    {% if books is empty %}
        <div class="text-center py-20 border border-dashed border-gray-100">
            <p class="text-secondary uppercase text-sm font-bold tracking-widest">Aucun ouvrage trouvé.</p>
        </div>
    {% else %}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-12 gap-y-16">
            {% for book in books %}
                <div class="group border border-gray-100 p-6 hover:border-primary transition duration-300 relative">
                    <div class="aspect-[3/4] bg-surface flex items-center justify-center mb-6 overflow-hidden">
                        <svg class="w-16 h-16 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253"></path></svg>
                    </div>
                    
                    <div class="flex flex-col h-full">
                        <div class="flex justify-between items-start mb-2">
                            <h3 class="text-sm font-bold uppercase tracking-tighter text-primary group-hover:underline">
                                <a href="{{ path('app_book_detail', {'id': book.id}) }}">{{ book.title }}</a>
                            </h3>
                            {% if book.availableCopies > 0 %}
                                <span class="text-[8px] bg-green-50 text-green-700 px-2 py-1 font-bold uppercase tracking-widest">Dispo</span>
                            {% else %}
                                <span class="text-[8px] bg-red-50 text-red-700 px-2 py-1 font-bold uppercase tracking-widest">Indispo</span>
                            {% endif %}
                        </div>
                        
                        <p class="text-xs text-secondary mt-1 line-clamp-1 italic uppercase tracking-tighter">
                            {% if book.authors|length > 0 %}
                                Par {{ book.authors[0].name }}{% if book.authors|length > 1 %}, ...{% endif %}
                            {% else %}
                                Auteur Inconnu
                            {% endif %}
                        </p>
                        
                        <div class="mt-6 pt-4 border-t border-gray-50 flex items-center justify-between">
                            <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">ISBN: {{ book.id }}</span>
                            <a href="{{ path('app_book_detail', {'id': book.id}) }}" class="text-[10px] font-bold uppercase tracking-widest text-primary border-b border-primary hover:text-accent hover:border-accent transition">Consulter &rarr;</a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
