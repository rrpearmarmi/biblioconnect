{% extends 'base.html.twig' %}

{% block title %}Administration - BiblioConnect{% endblock %}

{% block body %}
<div class="bg-surface py-12 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-end">
        <div>
            <h2 class="text-xs font-bold uppercase tracking-widest text-secondary mb-2 underline decoration-gray-300 underline-offset-8">Accès Total</h2>
            <h1 class="text-3xl font-bold tracking-tighter text-primary uppercase">Administration Système</h1>
        </div>
        <div class="flex gap-4">
             <a href="{{ path('app_librarian_book_new') }}" class="bg-primary text-white px-6 py-2 font-bold uppercase tracking-widest hover:bg-black transition text-[10px]">Ajouter un ouvrage</a>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 py-8 border-t border-gray-100 mt-8">
            <div>
                <span class="block text-[8px] uppercase tracking-[0.2em] text-gray-400 mb-2">Utilisateurs</span>
                <span class="text-3xl font-bold tracking-tighter text-primary">{{ total_users }}</span>
            </div>
            <div>
                <span class="block text-[8px] uppercase tracking-[0.2em] text-gray-400 mb-2">Catalogue</span>
                <span class="text-3xl font-bold tracking-tighter text-primary">{{ total_books }}</span>
            </div>
            <div>
                <span class="block text-[8px] uppercase tracking-[0.2em] text-gray-400 mb-2">Total Réservations</span>
                <span class="text-3xl font-bold tracking-tighter text-primary">{{ total_reservations }}</span>
            </div>
             <div>
                <span class="block text-[8px] uppercase tracking-[0.2em] text-gray-400 mb-2">À Modérer</span>
                <span class="text-3xl font-bold tracking-tighter {% if reviews_to_moderate|length > 0 %}text-red-600 animate-pulse{% else %}text-primary{% endif %}">{{ reviews_to_moderate|length }}</span>
            </div>
        </div>
    </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20" x-data="{ tab: 'users' }">
    <div class="flex gap-12 border-b border-gray-100 mb-16 overflow-x-auto whitespace-nowrap">
        <button @click="tab = 'users'" :class="tab === 'users' ? 'border-primary text-primary' : 'border-transparent text-secondary hover:text-primary'" class="pb-6 border-b-2 text-xs font-bold uppercase tracking-widest transition duration-200">Comptes ({{ users|length }})</button>
        <button @click="tab = 'catalogue'" :class="tab === 'catalogue' ? 'border-primary text-primary' : 'border-transparent text-secondary hover:text-primary'" class="pb-6 border-b-2 text-xs font-bold uppercase tracking-widest transition duration-200">Catalogue ({{ books|length }})</button>
        <button @click="tab = 'stocks'" :class="tab === 'stocks' ? 'border-primary text-primary' : 'border-transparent text-secondary hover:text-primary'" class="pb-6 border-b-2 text-xs font-bold uppercase tracking-widest transition duration-200">Flux & Stocks ({{ pending_reservations|length }} En attente)</button>
        <button @click="tab = 'history'" :class="tab === 'history' ? 'border-primary text-primary' : 'border-transparent text-secondary hover:text-primary'" class="pb-6 border-b-2 text-xs font-bold uppercase tracking-widest transition duration-200">Historique Global</button>
        <button @click="tab = 'moderation'" :class="tab === 'moderation' ? 'border-primary text-primary' : 'border-transparent text-secondary hover:text-primary'" class="pb-6 border-b-2 text-xs font-bold uppercase tracking-widest transition duration-200 underline decoration-red-200">Modération ({{ reviews_to_moderate|length }})</button>
    </div>

    <!-- Users Tab -->
    <div x-show="tab === 'users'" x-cloak class="space-y-6">
        <div class="bg-white border border-gray-100 overflow-hidden overflow-x-auto">
             <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-surface border-b border-gray-100 uppercase tracking-widest text-[10px] font-bold text-secondary">
                        <th class="px-6 py-4">Utilisateur</th>
                        <th class="px-6 py-4">Rôles</th>
                        <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50 text-[10px] font-bold">
                    {% for user in users %}
                        <tr class="hover:bg-gray-50 uppercase tracking-tighter">
                            <td class="px-6 py-6 text-primary">{{ user.email }}</td>
                            <td class="px-6 py-6 text-secondary">
                                {% for role in user.roles %}
                                    <span class="inline-block px-2 py-1 bg-gray-50 border border-gray-100 text-[8px] mr-1">{{ role|replace({'ROLE_': ''}) }}</span>
                                {% endfor %}
                            </td>
                            <td class="px-6 py-6 text-right space-x-4">
                                <a href="{{ path('app_admin_user_toggle_role', {'id': user.id}) }}" class="text-primary hover:underline">Permuter Biblio</a>
                                <a href="{{ path('app_admin_user_ban', {'id': user.id}) }}" class="text-red-600 hover:underline">Bannir</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Catalogue Tab -->
    <div x-show="tab === 'catalogue'" x-cloak class="space-y-6">
        <div class="bg-white border border-gray-100 overflow-hidden overflow-x-auto">
             <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-surface border-b border-gray-100 uppercase tracking-widest text-[10px] font-bold text-secondary">
                        <th class="px-6 py-4">Ouvrage</th>
                        <th class="px-6 py-4">Stock</th>
                        <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50 text-[10px] font-bold">
                    {% for book in books %}
                        <tr class="hover:bg-gray-50">
                            <td class="px-6 py-6 text-primary uppercase">{{ book.title }}</td>
                            <td class="px-6 py-6 uppercase tracking-widest {% if book.availableCopies < 2 %}text-red-500{% endif %}">
                                {{ book.availableCopies }} / {{ book.totalCopies }}
                            </td>
                            <td class="px-6 py-6 text-right space-x-4">
                                <a href="{{ path('app_librarian_book_edit', {'id': book.id}) }}" class="text-primary hover:underline uppercase">Éditer</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Stocks & Pending Tab -->
    <div x-show="tab === 'stocks'" x-cloak class="space-y-12">
        <div>
            <h3 class="text-[10px] font-bold uppercase tracking-widest text-primary mb-6">Réservations en attente</h3>
            <div class="bg-white border border-gray-100 overflow-hidden overflow-x-auto">
                 <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-surface border-b border-gray-100 uppercase tracking-widest text-[10px] font-bold text-secondary">
                            <th class="px-6 py-4">Livre</th>
                            <th class="px-6 py-4">Usager</th>
                            <th class="px-6 py-4">Date</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50 text-[10px] font-bold">
                        {% for res in pending_reservations %}
                            <tr>
                                <td class="px-6 py-6 text-primary uppercase">{{ res.book.title }}</td>
                                <td class="px-6 py-6 text-secondary">{{ res.user.email }}</td>
                                <td class="px-6 py-6 uppercase tracking-widest text-gray-400">{{ res.startDate|date('d M') }} - {{ res.endDate|date('d M') }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- History Tab -->
    <div x-show="tab === 'history'" x-cloak class="space-y-6">
        <div class="bg-white border border-gray-100 overflow-hidden overflow-x-auto">
             <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-surface border-b border-gray-100 uppercase tracking-widest text-[10px] font-bold text-secondary">
                        <th class="px-6 py-4">ID</th>
                        <th class="px-6 py-4">Livre</th>
                        <th class="px-6 py-4">Usager</th>
                        <th class="px-6 py-4">Statut</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50 text-[8px] font-bold">
                    {% for res in reservations %}
                        <tr class="uppercase">
                            <td class="px-6 py-6 text-gray-400">#{{ res.id }}</td>
                            <td class="px-6 py-6 text-primary">{{ res.book.title }}</td>
                            <td class="px-6 py-6 text-secondary">{{ res.user.email }}</td>
                            <td class="px-6 py-6">
                                <span class="px-2 py-1 {% if res.status == 'active' %}bg-green-50 text-green-700{% elseif res.status == 'cancelled' %}bg-red-50 text-red-700{% else %}bg-gray-50 text-gray-400{% endif %}">
                                    {{ res.status }}
                                </span>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Moderation Tab -->
    <div x-show="tab === 'moderation'" x-cloak class="space-y-6">
        {% if reviews_to_moderate is empty %}
            <div class="bg-white border border-gray-100 p-8 text-center sm:p-24 border-dashed">
                <p class="text-secondary text-xs uppercase font-bold tracking-widest">Aucun commentaire en attente de modération.</p>
            </div>
        {% else %}
            <div class="grid grid-cols-1 gap-6">
                {% for review in reviews_to_moderate %}
                    <div class="bg-white border border-gray-100 p-8 flex justify-between items-start">
                        <div>
                            <span class="block text-[8px] uppercase font-bold text-gray-400 mb-2">Par : {{ review.user.email }} | Sur : {{ review.book.title }}</span>
                            <p class="text-xs text-secondary italic">"{{ review.comment }}"</p>
                        </div>
                        <div class="flex flex-col gap-2">
                             <a href="{{ path('app_review_moderate', {'id': review.id, 'action': 'show'}) }}" class="bg-primary text-white px-6 py-2 font-bold uppercase tracking-widest hover:bg-black transition text-[8px] text-center">Approuver</a>
                             <a href="{{ path('app_review_moderate', {'id': review.id, 'action': 'hide'}) }}" class="border border-primary text-primary px-6 py-2 font-bold uppercase tracking-widest hover:bg-red-50 transition text-[8px] text-center">Masquer</a>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
