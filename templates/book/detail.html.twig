{% extends 'base.html.twig' %}

{% block title %}{{ book.title }} - BiblioConnect{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Breadcrumb -->
    <nav class="flex text-sm text-gray-500 mb-8" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3">
            <li class="inline-flex items-center">
                <a href="{{ path('app_home') }}" class="hover:text-amber-500 transition">Accueil</a>
            </li>
            <li>
                <div class="flex items-center">
                    <svg class="w-4 h-4 mx-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg>
                    <a href="{{ path('app_book_catalog') }}" class="hover:text-amber-500 transition">Catalogue</a>
                </div>
            </li>
            <li aria-current="page">
                <div class="flex items-center">
                    <svg class="w-4 h-4 mx-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg>
                    <span class="text-gray-400 truncate w-32 md:w-auto">{{ book.title }}</span>
                </div>
            </li>
        </ol>
    </nav>

    <!-- Content -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
        <!-- Image Column -->
        <div class="md:col-span-4 lg:col-span-3">
            <div class="rounded-xl overflow-hidden shadow-2xl border border-gray-200 dark:border-navy-700 bg-white dark:bg-navy-800 relative group">
                {% if book.coverImage %}
                    <img src="{{ asset('uploads/covers/' ~ book.coverImage) }}" alt="Couverture {{ book.title }}" class="w-full object-cover">
                {% else %}
                    <div class="w-full aspect-[2/3] bg-gradient-to-br from-navy-100 to-navy-200 dark:from-navy-800 dark:to-navy-900 flex items-center justify-center">
                        <svg class="w-20 h-20 text-navy-300 dark:text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                    </div>
                {% endif %}
                
                <div class="absolute inset-0 bg-gradient-to-t from-navy-950/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end justify-center pb-6">
                    <button class="bg-white/20 backdrop-blur-md border border-white/30 text-white rounded-full p-3 hover:bg-white/40 transition shadow-lg" title="Ajouter aux favoris">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
                    </button>
                </div>
            </div>
            
            <div class="mt-6 glass-panel rounded-xl p-6 border border-gray-100 dark:border-navy-700">
                <h4 class="text-sm font-semibold text-gray-900 dark:text-cream mb-4 uppercase tracking-wider">Disponibilité</h4>
                <div class="space-y-4">
                    <div class="flex justify-between items-center">
                        <span class="text-sm text-gray-600 dark:text-gray-400">Exemplaires</span>
                        <span class="text-sm font-medium dark:text-gray-200">{{ book.totalCopies }}</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-sm text-gray-600 dark:text-gray-400">Disponibles</span>
                        <span class="text-sm font-medium {% if book.availableCopies > 0 %}text-green-600 dark:text-green-400{% else %}text-red-500 dark:text-red-400{% endif %}">{{ book.availableCopies }}</span>
                    </div>
                    
                    <div class="pt-4 border-t border-gray-200 dark:border-navy-700">
                        {% if book.availableCopies > 0 %}
                            <form action="#" method="post">
                                <button type="submit" class="w-full py-3 bg-amber-500 hover:bg-amber-400 text-navy-950 font-semibold rounded-lg shadow-md transition-colors text-sm">
                                    Réserver ce livre
                                </button>
                            </form>
                        {% else %}
                            <button disabled class="w-full py-3 bg-gray-300 dark:bg-navy-800 text-gray-500 dark:text-gray-400 font-semibold rounded-lg cursor-not-allowed text-sm">
                                Indisponible
                            </button>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        <!-- Details Column -->
        <div class="md:col-span-8 lg:col-span-9">
            <div class="mb-4 flex flex-wrap gap-2">
                {% for category in book.categories %}
                    <span class="px-3 py-1 bg-amber-500/10 text-amber-600 dark:text-amber-400 text-xs font-bold rounded-full uppercase tracking-wide border border-amber-500/20">{{ category.name }}</span>
                {% endfor %}
            </div>
            
            <h1 class="text-4xl md:text-5xl font-serif font-bold text-navy-900 dark:text-white leading-tight mb-2">
                {{ book.title }}
            </h1>
            
            <p class="text-xl text-gray-600 dark:text-gray-300 mb-8 font-light">
                De {% for author in book.authors %}<a href="#" class="text-amber-600 hover:underline">{{ author.name }}</a>{% if not loop.last %}, {% endif %}{% endfor %}
            </p>

            <!-- Book Meta info -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6 py-6 border-y border-gray-200 dark:border-navy-700 mb-8">
                <div>
                    <h5 class="text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400 font-semibold mb-1">Année</h5>
                    <p class="text-gray-900 dark:text-gray-200 font-medium">{{ book.publishedYear|default('Non spécifié') }}</p>
                </div>
                <div>
                    <h5 class="text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400 font-semibold mb-1">Langue</h5>
                    <p class="text-gray-900 dark:text-gray-200 font-medium">{{ book.language ? book.language.name : 'Non spécifié' }}</p>
                </div>
                <div>
                    <h5 class="text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400 font-semibold mb-1">Avis ({{ book.reviews|length }})</h5>
                    <div class="flex items-center gap-1">
                        {% set totalRating = 0 %}
                        {% for review in book.reviews %}
                            {% set totalRating = totalRating + review.rating %}
                        {% endfor %}
                        {% set avg = book.reviews|length > 0 ? (totalRating / book.reviews|length)|round(1) : 0 %}
                        
                        <span class="text-gray-900 dark:text-gray-200 font-bold">{{ avg > 0 ? avg : '-' }}</span>
                        <svg class="w-4 h-4 text-amber-500" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                    </div>
                </div>
            </div>

            <!-- Description -->
            <div class="prose prose-lg dark:prose-invert max-w-none mb-12 text-gray-700 dark:text-gray-300">
                <h3 class="font-serif text-2xl font-bold text-navy-900 dark:text-white mb-4">À propos de l'ouvrage</h3>
                {{ book.description|nl2br }}
            </div>

            <!-- Reviews -->
            <div>
                <h3 class="font-serif text-2xl font-bold text-navy-900 dark:text-white mb-6">Avis des lecteurs</h3>
                
                <div class="space-y-6">
                    {% for review in book.reviews %}
                        {% if review.isVisible and review.isModerated %}
                            <div class="bg-white dark:bg-navy-900 p-6 rounded-xl border border-gray-100 dark:border-navy-700 shadow-sm">
                                <div class="flex items-center justify-between mb-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-full bg-navy-100 dark:bg-navy-800 flex items-center justify-center text-navy-900 dark:text-cream font-bold">
                                            {{ review.user.firstName[0] }}{{ review.user.lastName[0] }}
                                        </div>
                                        <div>
                                            <p class="font-medium text-gray-900 dark:text-white">{{ review.user.firstName }} {{ review.user.lastName|slice(0,1) }}.</p>
                                            <p class="text-xs text-gray-500">{{ review.createdAt|date('d/m/Y') }}</p>
                                        </div>
                                    </div>
                                    <div class="flex text-amber-500">
                                        {% for i in 1..5 %}
                                            <svg class="w-4 h-4 {% if i <= review.rating %}fill-current{% else %}text-gray-300 dark:text-gray-600{% endif %}" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                                        {% endfor %}
                                    </div>
                                </div>
                                <p class="text-gray-600 dark:text-gray-300 italic">"{{ review.comment }}"</p>
                            </div>
                        {% endif %}
                    {% else %}
                        <p class="text-gray-500 dark:text-gray-400 italic">Aucun avis pour le moment.</p>
                    {% endfor %}
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}
