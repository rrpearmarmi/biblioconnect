<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}BiblioConnect{% endblock %}</title>

    <meta name="description" content="Plateforme de gestion moderne pour votre bibliothèque en ligne.">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
    
    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.13.3/dist/cdn.min.js"></script>

    <!-- Tailwind CSS (CDN for demo speed; in production use AssetMapper/Vite) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Playfair Display', 'serif'],
                    },
                    colors: {
                        navy: {
                            50: '#f0f3fa',
                            100: '#e1e7f5',
                            800: '#1e293b',
                            900: '#0F172A',
                            950: '#020617',
                        },
                        amber: {
                            400: '#fbbf24',
                            500: '#F59E0B',
                            600: '#d97706',
                        },
                        cream: '#FDF8F0',
                    }
                }
            }
        }
    </script>
    
    <style>
        .glass-panel {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.18);
        }
        .dark .glass-panel {
            background: rgba(15, 23, 42, 0.7);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        .hero-gradient {
            background: linear-gradient(135deg, #FDF8F0 0%, #e1e7f5 100%);
        }
        .dark .hero-gradient {
            background: linear-gradient(135deg, #0F172A 0%, #020617 100%);
        }
        [x-cloak] { display: none !important; }
    </style>

    {% block stylesheets %}{% endblock %}
    {% block javascripts %}{% endblock %}
</head>
<body class="bg-cream text-navy-900 font-sans antialiased dark:bg-navy-950 dark:text-gray-100 transition-colors duration-300" x-data="{ darkMode: false }" :class="{ 'dark': darkMode }">

    <!-- Navbar -->
    <nav class="sticky top-0 z-50 glass-panel border-b border-gray-200 dark:border-navy-800">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <!-- Logo -->
                <div class="flex items-center">
                    <a href="{{ path('app_home') }}" class="flex items-center gap-2">
                        <svg class="w-8 h-8 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                        <span class="font-serif font-bold text-xl tracking-tight">Biblio<span class="text-amber-500">Connect</span></span>
                    </a>
                </div>

                <!-- Desktop Menu -->
                <div class="hidden sm:flex sm:items-center sm:space-x-8">
                    <a href="{{ path('app_book_catalog') }}" class="text-gray-700 hover:text-amber-500 dark:text-gray-300 dark:hover:text-amber-400 font-medium transition-colors">Catalogue</a>
                    
                    {% if app.user %}
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('app_admin_dashboard') }}" class="text-gray-700 hover:text-amber-500 dark:text-gray-300 dark:hover:text-amber-400 font-medium transition-colors">Administration</a>
                        {% elseif is_granted('ROLE_LIBRARIAN') %}
                            <a href="{{ path('app_librarian_dashboard') }}" class="text-gray-700 hover:text-amber-500 dark:text-gray-300 dark:hover:text-amber-400 font-medium transition-colors">Espace Bibliothécaire</a>
                        {% else %}
                            <a href="{{ path('app_user_dashboard') }}" class="text-gray-700 hover:text-amber-500 dark:text-gray-300 dark:hover:text-amber-400 font-medium transition-colors">Mon Espace</a>
                        {% endif %}

                        <a href="{{ path('app_logout') }}" class="px-4 py-2 rounded-md bg-navy-900 text-cream hover:bg-navy-800 dark:bg-navy-800 dark:hover:bg-navy-700 transition font-medium text-sm">Déconnexion</a>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="text-gray-700 hover:text-amber-500 dark:text-gray-300 dark:hover:text-amber-400 font-medium transition-colors">Connexion</a>
                        <a href="{{ path('app_register') }}" class="px-4 py-2 rounded-md bg-amber-500 text-navy-950 font-medium hover:bg-amber-400 shadow-sm transition text-sm">S'inscrire</a>
                    {% endif %}

                    <!-- Dark mode toggle -->
                    <button @click="darkMode = !darkMode" class="text-gray-500 hover:text-amber-500 focus:outline-none">
                        <svg x-show="!darkMode" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
                        <svg x-show="darkMode" x-cloak class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <!-- Flash Messages -->
    <div class="fixed top-20 right-4 z-50 flex flex-col gap-2">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div x-data="{ show: true }" x-show="show" x-init="setTimeout(() => show = false, 5000)" 
                     class="px-4 py-3 rounded-md shadow-lg {% if label == 'success' %}bg-green-100 text-green-800 border border-green-200{% elseif label == 'error' %}bg-red-100 text-red-800 border border-red-200{% else %}bg-blue-100 text-blue-800 border border-blue-200{% endif %} flex justify-between items-center"
                     x-transition.duration.300ms>
                    <span>{{ message }}</span>
                    <button @click="show = false" class="ml-4 text-gray-500 hover:text-gray-700">&times;</button>
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    <!-- Main Content -->
    <main class="min-h-[calc(100vh-4rem-12rem)] flex flex-col">
        {% block body %}{% endblock %}
    </main>

    <!-- Footer -->
    <footer class="bg-navy-950 text-gray-400 py-12 mt-auto border-t border-navy-800">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-3 gap-8">
            <div>
                <a href="{{ path('app_home') }}" class="flex items-center gap-2 mb-4">
                    <svg class="w-6 h-6 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                    <span class="font-serif font-bold text-lg text-cream tracking-tight">Biblio<span class="text-amber-500">Connect</span></span>
                </a>
                <p class="text-sm">Votre bibliothèque en ligne intelligente. Explorez, réservez et plongez dans de nouvelles aventures.</p>
            </div>
            <div>
                <h4 class="text-cream font-medium mb-4">Navigation</h4>
                <ul class="space-y-2 text-sm">
                    <li><a href="{{ path('app_home') }}" class="hover:text-amber-500 transition">Accueil</a></li>
                    <li><a href="{{ path('app_book_catalog') }}" class="hover:text-amber-500 transition">Catalogue</a></li>
                    <li><a href="#" class="hover:text-amber-500 transition">FAQ</a></li>
                    <li><a href="#" class="hover:text-amber-500 transition">Contact</a></li>
                </ul>
            </div>
            <div>
                <h4 class="text-cream font-medium mb-4">Informations</h4>
                <ul class="space-y-2 text-sm">
                    <li><a href="#" class="hover:text-amber-500 transition">Mentions Légales</a></li>
                    <li><a href="#" class="hover:text-amber-500 transition">Confidentialité</a></li>
                    <li><a href="#" class="hover:text-amber-500 transition">Conditions d'utilisation</a></li>
                </ul>
            </div>
        </div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-12 pt-8 border-t border-navy-800 text-sm text-center">
            <p>&copy; {{ 'now'|date('Y') }} BiblioConnect. Tous droits réservés.</p>
        </div>
    </footer>

</body>
</html>
