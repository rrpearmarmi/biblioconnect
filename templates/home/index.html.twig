{% extends 'base.html.twig' %}

{% block title %}BiblioConnect - Votre Bibliothèque Moderne{% endblock %}

{% block body %}
    <!-- Hero Section -->
    <div class="relative overflow-hidden hero-gradient border-b border-gray-200 dark:border-navy-800">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32 relative z-10">
            <div class="flex flex-col lg:flex-row items-center justify-between gap-12">
                <div class="lg:w-1/2 flex flex-col items-center lg:items-start text-center lg:text-left">
                    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-amber-500/10 text-amber-600 dark:text-amber-400 text-sm font-medium mb-6 border border-amber-500/20">
                        <span class="relative flex h-2 w-2">
                          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
                          <span class="relative inline-flex rounded-full h-2 w-2 bg-amber-500"></span>
                        </span>
                        Nouveau : Emprunt illimité jusqu'en fin de mois
                    </div>

                    <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight mb-6 text-navy-900 dark:text-cream leading-tight">
                        Découvrez un monde de <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-500 to-amber-600">savoirs</span> sans limites
                    </h1>
                    
                    <p class="text-xl text-gray-600 dark:text-gray-300 mb-10 max-w-2xl font-light">
                        Explorez des milliers d'ouvrages, réservez en un clic, et gérez vos emprunts depuis notre plateforme intuitive conçue pour les passionnés de lecture.
                    </p>

                    <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
                        <a href="{{ path('app_book_catalog') }}" class="px-8 py-4 rounded-lg bg-amber-500 text-navy-950 font-semibold hover:bg-amber-400 shadow-lg shadow-amber-500/30 transition-all flex justify-center items-center gap-2">
                            Explorer le Catalogue
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                        </a>
                        {% if not app.user %}
                        <a href="{{ path('app_register') }}" class="px-8 py-4 rounded-lg bg-white dark:bg-navy-900 text-navy-900 dark:text-cream font-semibold hover:bg-gray-50 dark:hover:bg-navy-800 shadow-md border border-gray-200 dark:border-navy-700 transition-all text-center">
                            S'inscrire gratuitement
                        </a>
                        {% endif %}
                    </div>
                </div>

                <!-- Abstract Hero Graphic (CSS generated) -->
                <div class="lg:w-1/2 relative w-full h-[400px] flex justify-center items-center perspective-1000">
                    <div class="absolute inset-0 bg-gradient-to-tr from-amber-500/20 to-transparent rounded-full blur-3xl"></div>
                    <div class="relative w-64 h-80 bg-white dark:bg-navy-800 rounded-xl shadow-2xl transform rotate-y-n12 rotate-z-6 border border-gray-100 dark:border-navy-700 glass-panel overflow-hidden z-20 group hover:rotate-0 hover:scale-105 transition-all duration-500 cursor-pointer">
                        <div class="h-48 bg-gradient-to-br from-amber-400 to-amber-600"></div>
                        <div class="p-6">
                            <div class="h-4 bg-gray-200 dark:bg-navy-700 rounded w-3/4 mb-3"></div>
                            <div class="h-3 bg-gray-100 dark:bg-navy-600 rounded w-1/2 left-0"></div>
                        </div>
                    </div>
                    <div class="absolute -bottom-10 -right-10 w-56 h-72 bg-white dark:bg-navy-900 rounded-xl shadow-xl transform rotate-12 border border-gray-200 dark:border-navy-800 object-cover opacity-80 z-10 transition-all duration-500">
                        <div class="h-full w-full bg-gradient-to-tr from-navy-800 to-navy-600 flex items-center justify-center">
                            <svg class="w-16 h-16 text-navy-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Decorative SVG wave -->
        <div class="absolute bottom-0 w-full overflow-hidden leading-none">
            <svg class="relative block w-full h-12 text-cream dark:text-navy-950" data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
                <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C52.16,108.9,106.9,118.12,162.7,117.5,236.19,116.7,309.2,95.5,321.39,56.44Z" fill="currentColor"></path>
            </svg>
        </div>
    </div>

    <!-- Featured Books Section -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
        <div class="flex justify-between items-end mb-12">
            <div>
                <h2 class="text-sm uppercase tracking-wider font-bold text-amber-500 mb-2">Sélection</h2>
                <h3 class="font-serif text-3xl md:text-4xl font-bold dark:text-cream">Nouveautés à l'affiche</h3>
            </div>
            <a href="{{ path('app_book_catalog') }}" class="hidden sm:flex items-center gap-2 text-navy-800 dark:text-gray-300 hover:text-amber-500 font-medium transition group">
                Voir tout le catalogue
                <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-6">
            {% for book in featuredBooks %}
                <a href="{{ path('app_book_detail', {id: book.id}) }}" class="group block glass-panel rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 border border-gray-100 dark:border-navy-800 flex flex-col h-full">
                    <div class="aspect-[2/3] relative bg-gray-200 dark:bg-navy-800 overflow-hidden">
                        {% if book.coverImage %}
                            <img src="{{ asset('uploads/covers/' ~ book.coverImage) }}" alt="Couverture {{ book.title }}" class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-500">
                        {% else %}
                            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-navy-100 to-navy-200 dark:from-navy-800 dark:to-navy-900 group-hover:scale-105 transition-transform duration-500">
                                <svg class="w-12 h-12 text-navy-300 dark:text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                            </div>
                        {% endif %}
                        <!-- Badges/Overlay -->
                        <div class="absolute top-2 right-2 flex flex-col gap-1">
                            {% if book.availableCopies > 0 %}
                                <span class="bg-green-500/90 text-white text-[10px] font-bold px-2 py-1 rounded shadow-sm backdrop-blur-md uppercase tracking-wider">Dispo</span>
                            {% else %}
                                <span class="bg-red-500/90 text-white text-[10px] font-bold px-2 py-1 rounded shadow-sm backdrop-blur-md uppercase tracking-wider">Emprunté</span>
                            {% endif %}
                        </div>
                    </div>
                    <div class="p-4 flex-1 flex flex-col">
                        <div class="uppercase text-[10px] tracking-wider text-amber-600 dark:text-amber-500 mb-1 font-semibold truncate">
                            {% for cat in book.categories|slice(0, 1) %}{{ cat.name }}{% endfor %}
                        </div>
                        <h4 class="font-serif font-bold text-navy-900 dark:text-white leading-tight mb-1 truncate">{{ book.title }}</h4>
                        <p class="text-xs text-gray-500 dark:text-gray-400 truncate w-full flex-1">
                            {% for a in book.authors %}{{ a.name }}{% if not loop.last %}, {% endif %}{% endfor %}
                        </p>
                    </div>
                </a>
            {% else %}
                <div class="col-span-full py-12 text-center text-gray-500 bg-white/50 dark:bg-navy-800/50 rounded-xl border border-dashed border-gray-300 dark:border-navy-700">
                    <p>Aucun livre disponible dans le catalogue pour le moment.</p>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
