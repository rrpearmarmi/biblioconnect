{% extends 'base.html.twig' %}

{% block title %}Connexion - BiblioConnect{% endblock %}

{% block body %}
<div class="flex-1 flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8 relative">
    <!-- Abstract background -->
    <div class="absolute inset-0 z-0 overflow-hidden">
        <div class="absolute -top-40 -left-40 w-80 h-80 bg-amber-500/20 rounded-full blur-3xl"></div>
        <div class="absolute top-40 -right-40 w-96 h-96 bg-navy-500/10 dark:bg-navy-800/50 rounded-full blur-3xl"></div>
    </div>

    <div class="max-w-md w-full space-y-8 glass-panel dark:bg-navy-900/80 p-8 rounded-2xl shadow-xl border border-white/20 dark:border-navy-700 relative z-10">
        <div>
            <div class="flex justify-center">
                <div class="w-16 h-16 bg-gradient-to-tr from-amber-400 to-amber-600 rounded-2xl shadow-lg flex items-center justify-center text-white transform -rotate-6">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                </div>
            </div>
            <h2 class="mt-6 text-center text-3xl font-serif font-bold text-navy-900 dark:text-white">
                Ravi de vous revoir
            </h2>
            <p class="mt-2 text-center text-sm text-gray-600 dark:text-gray-400">
                Ou
                <a href="{{ path('app_register') }}" class="font-medium text-amber-600 hover:text-amber-500 transition">
                    créez votre compte gratuitement
                </a>
            </p>
        </div>
        
        <form class="mt-8 space-y-6" method="post">
            {% if error %}
                <div class="bg-red-50 dark:bg-red-900/30 text-red-700 dark:text-red-400 p-3 rounded-lg text-sm border border-red-200 dark:border-red-800">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {% if app.user %}
                <div class="bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 p-3 rounded-lg text-sm border border-blue-200 dark:border-blue-800">
                    Vous êtes connecté en tant que {{ app.user.userIdentifier }}, <a href="{{ path('app_logout') }}" class="font-bold underline">Se déconnecter</a>
                </div>
            {% endif %}

            <div class="rounded-md space-y-4">
                <div>
                    <label for="username" class="sr-only">Email</label>
                    <input type="email" value="{{ last_username }}" name="_username" id="username" class="appearance-none relative block w-full px-4 py-3 border border-gray-300 dark:border-navy-700 placeholder-gray-500 dark:placeholder-gray-400 text-gray-900 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 focus:z-10 sm:text-sm dark:bg-navy-800 transition-colors" placeholder="Adresse email" autocomplete="email" required autofocus>
                </div>
                <div>
                    <label for="password" class="sr-only">Mot de passe</label>
                    <input type="password" name="_password" id="password" class="appearance-none relative block w-full px-4 py-3 border border-gray-300 dark:border-navy-700 placeholder-gray-500 dark:placeholder-gray-400 text-gray-900 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 focus:z-10 sm:text-sm dark:bg-navy-800 transition-colors" placeholder="Mot de passe" autocomplete="current-password" required>
                </div>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <input id="remember_me" name="_remember_me" type="checkbox" class="h-4 w-4 text-amber-500 focus:ring-amber-500 border-gray-300 rounded dark:border-navy-600 dark:bg-navy-800">
                    <label for="remember_me" class="ml-2 block text-sm text-gray-900 dark:text-gray-300">
                        Se souvenir de moi
                    </label>
                </div>

                <div class="text-sm">
                    <a href="#" class="font-medium text-amber-600 hover:text-amber-500 transition">Mdp oublié ?</a>
                </div>
            </div>

            <div>
                <button type="submit" class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-medium rounded-lg text-navy-950 bg-amber-500 hover:bg-amber-400 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-amber-500 transition-all shadow-md shadow-amber-500/20">
                    <span class="absolute left-0 inset-y-0 flex items-center pl-3">
                        <svg class="h-5 w-5 text-amber-700 group-hover:text-amber-800 transition" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
                        </svg>
                    </span>
                    Se connecter
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
